{
  "name": "icyareta-ai",
  "version": "1.0.0",
  "description": "NESA Exam Prep Simulation Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:ingest": "ts-node --project tsconfig.json src/scripts/ingest.ts",
    "db:seed": "ts-node --project tsconfig.json src/scripts/seed.ts",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jo-rdan/icyareta-ai.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jo-rdan/icyareta-ai/issues"
  },
  "homepage": "https://github.com/jo-rdan/icyareta-ai#readme",
  "dependencies": {
    "@google/genai": "^1.43.0",
    "africastalking": "^0.7.9",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.19.0",
    "resend": "^6.9.4",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/africastalking": "^0.6.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
